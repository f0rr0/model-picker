{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "perf": "warn",
    "suspicious": "warn"
  },
  "ignorePatterns": [
    "node_modules",
    "public/r",
    "bun.lock",
    "demo/.next",
    "demo/next-env.d.ts"
  ],
  "options": {
    "typeAware": true
  },
  "plugins": ["typescript", "react", "jsx-a11y", "import", "unicorn", "oxc"],
  "rules": {
    "react/react-in-jsx-scope": "off"
  }
}

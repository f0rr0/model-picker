{
  "name": "model-picker",
  "version": "0.1.0",
  "description": "A shadcn-style source component for app-owned AI model selection with search, suggestions, reasoning, plan mode, and fast mode.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build:registry": "shadcn build",
    "check": "ultracite check --type-aware",
    "check:fix": "ultracite fix --type-aware",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint . --type-aware",
    "lint:fix": "oxlint . --fix --type-aware",
    "models:verify": "node scripts/verify-model-catalog.mjs",
    "prepare": "lefthook install",
    "registry:validate": "shadcn registry validate",
    "smoke:consumer": "node scripts/verify-consumer.mjs",
    "typecheck": "tsgo --noEmit",
    "validate": "bun run typecheck && bun run lint && bun run format:check && bun run registry:validate && bun run build:registry"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "lucide-react": "1.17.0",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@tanstack/ai": "0.23.1",
    "@tanstack/ai-openrouter": "0.10.0",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260527.2",
    "lefthook": "2.1.9",
    "motion": "12.40.0",
    "oxfmt": "0.52.0",
    "oxlint": "1.67.0",
    "oxlint-tsgolint": "0.23.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "shadcn": "4.9.0",
    "typescript": "6.0.3",
    "ultracite": "7.8.1"
  },
  "packageManager": "bun@1.3.8"
}

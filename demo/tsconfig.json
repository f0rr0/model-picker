{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "declaration": false,
    "incremental": true,
    "jsx": "preserve",
    "noEmit": true,
    "paths": {
      "@/*": ["./*"],
      "@/components/ui/*": ["./components/ui/*"],
      "@/lib/*": ["./lib/*"]
    },
    "types": ["react", "react-dom"]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/dev/types/**/*.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
